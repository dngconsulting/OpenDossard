# Application
NODE_ENV=development
PORT=3001

# PostgreSQL Database
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_USER=dossarduser
POSTGRES_PASSWORD=dossardpassword
POSTGRES_DB=dossarddb

# JWT Configuration
JWT_SECRET=your-super-secret-jwt-key-change-this-in-production
JWT_ACCESS_EXPIRE=15m
JWT_REFRESH_SECRET=your-super-secret-refresh-key-change-this-in-production
JWT_REFRESH_EXPIRE=7d

# CORS
CORS_ORIGINS=http://localhost:3000,http://localhost:5173

# HelloAsso OAuth (sandbox par défaut — basculer en prod = retirer "-sandbox")
HELLOASSO_CLIENT_ID=
HELLOASSO_CLIENT_SECRET=
HELLOASSO_OAUTH_BASE_URL=https://auth.helloasso-sandbox.com
HELLOASSO_API_BASE_URL=https://api.helloasso-sandbox.com
HELLOASSO_REDIRECT_URI=http://localhost:3001/api/v2/helloasso/oauth/callback
# Origine de la SPA vers laquelle le backend redirige (302) après le callback HelloAsso.
# Le path est ajouté par le backend : /club/{clubId}?status=success&slug=Y en succès,
# /clubs?status=error&reason=... en erreur. Pas de path à mettre ici, juste l'origine.
HELLOASSO_FRONT_RESULT_URL=http://localhost:5173
# Clé AES-256-GCM (32 octets base64) pour chiffrer les tokens HelloAsso en DB.
# Générer : node -e "console.log(require('crypto').randomBytes(32).toString('base64'))"
HELLOASSO_TOKEN_ENCRYPTION_KEY=
# Optionnel — TTL du cache de state OAuth (défaut 600s = 10 min)
# HELLOASSO_STATE_TTL_SECONDS=600
# URLs vers lesquelles HelloAsso redirige le navigateur APRÈS le paiement.
# Doivent être des deep links Dossardeur en prod ; en dev sandbox, des URLs web
# de fallback sont acceptables (HelloAsso impose HTTPS sauf pour les schemes custom).
HELLOASSO_PAYMENT_RETURN_URL_SUCCESS=dossardeur://payment/success
HELLOASSO_PAYMENT_RETURN_URL_ERROR=dossardeur://payment/error
HELLOASSO_PAYMENT_RETURN_URL_CANCELLED=dossardeur://payment/cancelled
# Clé de signature webhook HelloAsso — retournée par PUT /v5/partners/me/api-notifications
# au moment de l'enregistrement de l'URL webhook. Stocker tel quel (opaque côté HelloAsso).
HELLOASSO_WEBHOOK_SIGNATURE_KEY=
